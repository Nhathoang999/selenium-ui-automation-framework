<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="E-Commerce UI Automation Suite" parallel="tests" thread-count="2">
    
    <!-- Global Parameter: Can be overridden by Maven command line -->
    <parameter name="browser" value="chrome"/>

    <listeners>
        <!-- Allure Listener automatically generates test execution data -->
        <listener class-name="io.qameta.allure.testng.AllureTestNg"/>
    </listeners>

    <test name="Smoke Tests">
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>
        <classes>
            <class name="com.automation.tests.auth.LoginTest"/>
            <class name="com.automation.tests.catalog.CartTest"/>
        </classes>
    </test>

    <test name="Regression Tests">
        <groups>
            <run>
                <include name="regression"/>
            </run>
        </groups>
        <classes>
            <class name="com.automation.tests.auth.LoginTest"/>
            <class name="com.automation.tests.catalog.CatalogTest"/>
            <class name="com.automation.tests.catalog.CartTest"/>
            <class name="com.automation.tests.checkout.CheckoutTest"/>
        </classes>
    </test>
</suite>
